## =============================================================================
## 몽글픽 백엔드 환경변수 템플릿 (.env.example)
## =============================================================================
## 이 파일을 복사하여 .env로 만든 뒤 실제 값을 입력하세요:
##   cp .env.example .env
## =============================================================================

## -------------------------------------------------------------------------
## MySQL 데이터소스
## -------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/monglepick?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=monglepick
SPRING_DATASOURCE_PASSWORD=monglepick_dev

## -------------------------------------------------------------------------
## Redis (Spring Boot 기본값: localhost:6379)
## -------------------------------------------------------------------------
# SPRING_DATA_REDIS_HOST=localhost
# SPRING_DATA_REDIS_PORT=6379

## -------------------------------------------------------------------------
## 서버 설정
## -------------------------------------------------------------------------
SERVER_PORT=8080

## -------------------------------------------------------------------------
## JWT 인증
## -------------------------------------------------------------------------
## ⚠ 운영 환경에서는 256비트 이상의 안전한 랜덤 키로 반드시 교체하세요
JWT_SECRET=monglepick-dev-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256

## -------------------------------------------------------------------------
## 서비스 키 (Agent ↔ Backend 내부 통신)
## -------------------------------------------------------------------------
## ⚠ 운영 환경에서는 안전한 랜덤 키로 반드시 교체하세요
SERVICE_API_KEY=dev-service-key-change-me

## -------------------------------------------------------------------------
## OAuth2 소셜 로그인 (Google / Kakao / Naver)
## -------------------------------------------------------------------------
## 각 제공자의 개발자 콘솔에서 발급받은 키를 입력하세요
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret

NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

## -------------------------------------------------------------------------
## OAuth2 리다이렉트 URL (소셜 로그인 성공/실패 시 프론트엔드 이동)
## -------------------------------------------------------------------------
OAUTH_REDIRECT_URL=http://localhost:5173/cookie
OAUTH_FAILURE_URL=http://localhost:5173/login

## -------------------------------------------------------------------------
## CORS 허용 오리진
## -------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

## -------------------------------------------------------------------------
## 포인트 시스템
## -------------------------------------------------------------------------
FREE_POINTS_ON_SIGNUP=500
POINT_COST_PER_RECOMMENDATION=100

## -------------------------------------------------------------------------
## 관리자 시드 계정 (앱 기동 시 자동 생성)
## -------------------------------------------------------------------------
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=your-admin-password
ADMIN_NICKNAME=관리자

## -------------------------------------------------------------------------
## SQL 초기화 모드 (never / always)
## -------------------------------------------------------------------------
## 개발 환경에서 data.sql 시드 데이터 실행 시 always로 변경
SQL_INIT_MODE=never

## -------------------------------------------------------------------------
## Toss Payments 결제
## -------------------------------------------------------------------------
## ⚠ Toss 개발자센터에서 발급받은 테스트 키를 입력하세요
TOSS_SECRET_KEY=your-toss-secret-key
TOSS_CLIENT_KEY=your-toss-client-key
TOSS_BASE_URL=https://api.tosspayments.com/v1
